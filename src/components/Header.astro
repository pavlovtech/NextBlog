---
import { NAV_LINKS } from '../consts'
---

<header class="md:flex items-center justify-between py-10">
  <div>
    <div
      class="text-primary-color dark:text-primary-color-dark flex items-center justify-between text-xl font-semibold"
    >
      <a href="/"><span id="tw-path" class="tw-cursor"></span></a>
    </div>
  </div>
  <div class="flex items-center text-base leading-5 mt-5 md:mt-0">
    <nav class="sm:block">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class="link-underline rounded py-1 px-2 text-gray-900 hover:bg-gray-200 dark:text-gray-100 dark:hover:bg-gray-700 sm:py-2 sm:px-3"
          >
            {link.title}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  .tw-cursor::after {
    content: '▋';
    margin-left: 1px;
    animation: tw-blink 1s steps(1) infinite;
  }
  @keyframes tw-blink {
    50% {
      opacity: 0;
    }
  }
</style>

<script>
  // ~1 KB vanilla typewriter (replaces the React typewriter-effect island)
  const el = document.getElementById('tw-path')
  if (el) {
    const text = `~${location.pathname} `
    let i = 0
    const tick = () => {
      el.textContent = text.slice(0, i)
      if (i++ < text.length) setTimeout(tick, 45)
    }
    tick()
  }
</script>
