---
import { NAV_LINKS } from '../consts'
---

<header class="md:flex items-center justify-between py-10">
  <div>
    <div
      class="text-primary-color dark:text-primary-color-dark flex items-center justify-between text-xl font-semibold"
    >
      <a href="/"><span id="tw-path"></span></a>
    </div>
  </div>
  <div class="flex items-center text-base leading-5 mt-5 md:mt-0">
    <nav class="sm:block">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class="link-underline rounded py-1 px-2 text-gray-900 hover:bg-gray-200 dark:text-gray-100 dark:hover:bg-gray-700 sm:py-2 sm:px-3"
          >
            {link.title}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  // typewriter-effect's vanilla core (same engine the React wrapper used) — no React.
  // Re-runs on every navigation (astro:page-load) so it works with View Transitions.
  import Typewriter from 'typewriter-effect/dist/core'
  function initTypewriter() {
    const el = document.getElementById('tw-path')
    if (!el) return
    el.innerHTML = ''
    new Typewriter(el, {
      strings: [`~${location.pathname} `],
      autoStart: true,
      loop: false,
      deleteSpeed: 100000,
      delay: 0,
    })
  }
  document.addEventListener('astro:page-load', initTypewriter)
</script>
