---
import { getEntry, render } from 'astro:content'

const about = await getEntry('pages', 'about-me')
const Content = about ? (await render(about)).Content : null
---

<div class="pt-6">
  <h1
    class="pb-6 text-3xl font-extrabold leading-9 tracking-tight text-gray-900 dark:text-gray-100 sm:text-4xl sm:leading-10 md:text-6xl md:leading-14"
  >
    Hi, I am <span class="text-primary-color-500 dark:text-primary-color-dark-500">Alex</span>
  </h1>
  <div class="prose prose-invert max-w-none pt-5 text-lg text-gray-600 dark:text-gray-300">
    {Content && <Content />}
  </div>
  <p class="pt-10 text-lg leading-7 text-slate-600 dark:text-slate-300">
    This is my place for <span id="rn-highlight">thoughts, reflections &amp; everything&nbsp;</span>
    in between. Have a good read!
  </p>
</div>

<script>
  // vanilla rough-notation (replaces the React react-rough-notation island).
  // Re-runs on every navigation (astro:page-load) for View Transitions.
  import { annotate } from 'rough-notation'
  function initNotation() {
    const el = document.getElementById('rn-highlight')
    if (!el) return
    const annotation = annotate(el, {
      type: 'box',
      color: '#DE1D8D',
      animationDuration: 2500,
    })
    setTimeout(() => annotation.show(), 1000)
  }
  document.addEventListener('astro:page-load', initNotation)
</script>
